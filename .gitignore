# ========================
# NEXOVA — .gitignore
# ========================

# --- Environment ---
.env
.env.local
.env.*.local
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# --- Node.js ---
node_modules/
.next/
out/
.vercel/
.turbo/
*.tsbuildinfo

# --- Docker ---
docker-compose.override.yml

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# --- GCP ---
*.json
!package.json
!package-lock.json
!tsconfig.json
!tsconfig.*.json
!next.config.ts
!firebase.json
!**/fixtures/*.json
!public/manifest.json

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Testing ---
playwright-report/
test-results/
coverage/
